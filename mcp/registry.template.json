{
  "version": 1,
  "servers": {
    "work-global": {
      "enabled": true,
      "transport": "stdio",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceRoot}\\scripts\\run-filesystem-mcp.ps1"
      ]
    },
    "canva": {
      "enabled": true,
      "transport": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "mcp-remote@latest",
        "https://mcp.canva.com/mcp"
      ]
    },
    "awarewave-ops": {
      "enabled": true,
      "transport": "stdio",
      "optional_env": [
        "API_AWAREWAVE_BASE_URL",
        "API_AWAREWAVE_BEARER_TOKEN",
        "APP_AWAREWAVE_BASE_URL",
        "APP_AWAREWAVE_BEARER_TOKEN",
        "HETZNER_API_BASE_URL",
        "HETZNER_API_TOKEN",
        "UPTIME_KUMA_BASE_URL",
        "UPTIME_KUMA_API_KEY",
        "GRAFANA_BASE_URL",
        "GRAFANA_SERVICE_ACCOUNT_TOKEN",
        "GRAFANA_BASIC_USER",
        "GRAFANA_BASIC_PASSWORD",
        "NETDATA_BASE_URL",
        "NETDATA_API_TOKEN",
        "SLACK_API_BASE_URL",
        "SLACK_BOT_TOKEN",
        "SLACK_WEBHOOK_URL",
        "SENTRY_API_BASE_URL",
        "SENTRY_AUTH_TOKEN",
        "RESEND_API_BASE_URL",
        "RESEND_API_KEY",
        "CLOUDFLARE_API_BASE_URL",
        "CLOUDFLARE_API_TOKEN",
        "POSTHOG_API_BASE_URL",
        "POSTHOG_PERSONAL_API_KEY",
        "N8N_API_BASE_URL",
        "N8N_AUTH_BEARER_TOKEN",
        "N8N_API_KEY",
        "N8N_BASIC_AUTH_USER",
        "N8N_BASIC_AUTH_PASSWORD",
        "TRIGGER_API_URL",
        "TRIGGER_ACCESS_TOKEN",
        "SUPABASE_SOULFULEXPRESSION_URL",
        "SUPABASE_SOULFULEXPRESSION_SERVICE_ROLE_KEY",
        "SUPABASE_A_URL",
        "SUPABASE_A_SERVICE_ROLE_KEY",
        "SUPABASE_AWAREWAVE_URL",
        "SUPABASE_AWAREWAVE_SERVICE_ROLE_KEY",
        "SUPABASE_B_URL",
        "SUPABASE_B_SERVICE_ROLE_KEY"
      ],
      "command": "node",
      "args": [
        "${workspaceRoot}\\mcp-local-wrappers\\awarewave-ops-mcp.mjs"
      ],
      "env": {
        "API_AWAREWAVE_BASE_URL": "${env:API_AWAREWAVE_BASE_URL}",
        "API_AWAREWAVE_BEARER_TOKEN": "${env:API_AWAREWAVE_BEARER_TOKEN}",
        "APP_AWAREWAVE_BASE_URL": "${env:APP_AWAREWAVE_BASE_URL}",
        "APP_AWAREWAVE_BEARER_TOKEN": "${env:APP_AWAREWAVE_BEARER_TOKEN}",
        "HETZNER_API_BASE_URL": "${env:HETZNER_API_BASE_URL}",
        "HETZNER_API_TOKEN": "${env:HETZNER_API_TOKEN}",
        "UPTIME_KUMA_BASE_URL": "${env:UPTIME_KUMA_BASE_URL}",
        "UPTIME_KUMA_API_KEY": "${env:UPTIME_KUMA_API_KEY}",
        "GRAFANA_BASE_URL": "${env:GRAFANA_BASE_URL}",
        "GRAFANA_SERVICE_ACCOUNT_TOKEN": "${env:GRAFANA_SERVICE_ACCOUNT_TOKEN}",
        "GRAFANA_BASIC_USER": "${env:GRAFANA_BASIC_USER}",
        "GRAFANA_BASIC_PASSWORD": "${env:GRAFANA_BASIC_PASSWORD}",
        "NETDATA_BASE_URL": "${env:NETDATA_BASE_URL}",
        "NETDATA_API_TOKEN": "${env:NETDATA_API_TOKEN}",
        "SLACK_API_BASE_URL": "${env:SLACK_API_BASE_URL}",
        "SLACK_BOT_TOKEN": "${env:SLACK_BOT_TOKEN}",
        "SLACK_WEBHOOK_URL": "${env:SLACK_WEBHOOK_URL}",
        "SENTRY_API_BASE_URL": "${env:SENTRY_API_BASE_URL}",
        "SENTRY_AUTH_TOKEN": "${env:SENTRY_AUTH_TOKEN}",
        "RESEND_API_BASE_URL": "${env:RESEND_API_BASE_URL}",
        "RESEND_API_KEY": "${env:RESEND_API_KEY}",
        "CLOUDFLARE_API_BASE_URL": "${env:CLOUDFLARE_API_BASE_URL}",
        "CLOUDFLARE_API_TOKEN": "${env:CLOUDFLARE_API_TOKEN}",
        "POSTHOG_API_BASE_URL": "${env:POSTHOG_API_BASE_URL}",
        "POSTHOG_PERSONAL_API_KEY": "${env:POSTHOG_PERSONAL_API_KEY}",
        "N8N_API_BASE_URL": "${env:N8N_API_BASE_URL}",
        "N8N_AUTH_BEARER_TOKEN": "${env:N8N_AUTH_BEARER_TOKEN}",
        "N8N_API_KEY": "${env:N8N_API_KEY}",
        "N8N_BASIC_AUTH_USER": "${env:N8N_BASIC_AUTH_USER}",
        "N8N_BASIC_AUTH_PASSWORD": "${env:N8N_BASIC_AUTH_PASSWORD}",
        "TRIGGER_API_URL": "${env:TRIGGER_API_URL}",
        "TRIGGER_ACCESS_TOKEN": "${env:TRIGGER_ACCESS_TOKEN}",
        "SUPABASE_SOULFULEXPRESSION_URL": "${env:SUPABASE_SOULFULEXPRESSION_URL}",
        "SUPABASE_SOULFULEXPRESSION_SERVICE_ROLE_KEY": "${env:SUPABASE_SOULFULEXPRESSION_SERVICE_ROLE_KEY}",
        "SUPABASE_A_URL": "${env:SUPABASE_A_URL}",
        "SUPABASE_A_SERVICE_ROLE_KEY": "${env:SUPABASE_A_SERVICE_ROLE_KEY}",
        "SUPABASE_AWAREWAVE_URL": "${env:SUPABASE_AWAREWAVE_URL}",
        "SUPABASE_AWAREWAVE_SERVICE_ROLE_KEY": "${env:SUPABASE_AWAREWAVE_SERVICE_ROLE_KEY}",
        "SUPABASE_B_URL": "${env:SUPABASE_B_URL}",
        "SUPABASE_B_SERVICE_ROLE_KEY": "${env:SUPABASE_B_SERVICE_ROLE_KEY}"
      }
    },
    "copilot": {
      "enabled": true,
      "transport": "http",
      "url": "https://api.githubcopilot.com/mcp",
      "headers": {
        "Authorization": "Bearer ${env:COPILOT_MCP_BEARER_TOKEN}"
      },
      "codex": {
        "bearer_token_env_var": "COPILOT_MCP_BEARER_TOKEN"
      }
    },
    "github": {
      "enabled": true,
      "transport": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "airtable": {
      "enabled": true,
      "transport": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@loticdigital/airtable-mcp-server"
      ],
      "env": {
        "AIRTABLE_API_KEY": "${env:AIRTABLE_API_KEY}"
      }
    },
    "replicate": {
      "enabled": true,
      "transport": "stdio",
      "optional_env": [
        "REPLICATE_WEBHOOK_SIGNING_KEY"
      ],
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "replicate-mcp"
      ],
      "env": {
        "REPLICATE_API_TOKEN": "${env:REPLICATE_API_TOKEN}",
        "REPLICATE_WEBHOOK_SIGNING_KEY": "${env:REPLICATE_WEBHOOK_SIGNING_KEY}"
      }
    },
    "perplexity": {
      "enabled": true,
      "transport": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@perplexity-ai/mcp-server"
      ],
      "env": {
        "PERPLEXITY_API_KEY": "${env:PERPLEXITY_API_KEY}"
      }
    },
    "wordpress": {
      "enabled": true,
      "transport": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@automattic/mcp-wordpress-remote@latest"
      ],
      "env": {
        "WP_API_URL": "${env:WP_API_URL}",
        "JWT_TOKEN": "${env:WORDPRESS_JWT_TOKEN}"
      }
    },
    "n8n": {
      "enabled": true,
      "transport": "http",
      "url": "${env:N8N_MCP_URL}",
      "headers": {
        "Authorization": "Bearer ${env:N8N_AUTH_BEARER_TOKEN}"
      },
      "codex": {
        "bearer_token_env_var": "N8N_AUTH_BEARER_TOKEN"
      },
      "note": "Requires SSH tunnel: ssh -N -L 127.0.0.1:5678:127.0.0.1:5678 root@<your-vps-ip>"
    },
    "trigger": {
      "enabled": true,
      "transport": "stdio",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceRoot}\\scripts\\start-trigger-mcp.ps1",
        "-ProjectRef",
        "${env:TRIGGER_PROJECT_REF}"
      ],
      "env": {
        "TRIGGER_API_URL": "${env:TRIGGER_API_URL}"
      }
    },
    "supabase-awarewave-postgres": {
      "enabled": true,
      "transport": "stdio",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceRoot}\\scripts\\run-postgres-mcp.ps1"
      ],
      "env": {
        "SUPABASE_AWAREWAVE_POSTGRES_DSN": "${env:SUPABASE_AWAREWAVE_POSTGRES_DSN}"
      },
      "note": "Requires SSH tunnel: scripts/open-supabase-ssh-tunnel.ps1 -Background"
    },
    "supabase": {
      "enabled": true,
      "transport": "http",
      "clients": {
        "codex": {
          "exclude": true
        }
      },
      "url": "http://localhost:8000/mcp",
      "headers": {
        "Authorization": "Bearer ${env:SUPABASE_AUTH_BEARER_TOKEN}"
      },
      "codex": {
        "bearer_token_env_var": "SUPABASE_AUTH_BEARER_TOKEN"
      },
      "note": "Requires tunnel: scripts/open-supabase-ssh-tunnel.ps1 -Background (self-hosted /mcp is IP-restricted externally)"
    },
    "supabase-soulfulexpression": {
      "enabled": true,
      "transport": "http",
      "clients": {
        "codex": {
          "exclude": true
        }
      },
      "url": "https://mcp.supabase.com/mcp?project_ref=mffjqjiidbeibilmxzef&features=database,docs,development,debugging",
      "headers": {
        "Authorization": "Bearer ${env:SUPABASE_SOULFULEXPRESSION_AUTH_BEARER_TOKEN}"
      }
    },
    "cloudflare": {
      "enabled": true,
      "transport": "http",
      "url": "https://mcp.cloudflare.com/mcp",
      "headers": {
        "Authorization": "Bearer ${env:CLOUDFLARE_AUTH_BEARER_TOKEN}"
      },
      "codex": {
        "bearer_token_env_var": "CLOUDFLARE_AUTH_BEARER_TOKEN"
      }
    },
    "posthog": {
      "enabled": true,
      "transport": "http",
      "url": "https://mcp.posthog.com/mcp",
      "headers": {
        "Authorization": "Bearer ${env:POSTHOG_PERSONAL_API_KEY}"
      },
      "codex": {
        "bearer_token_env_var": "POSTHOG_PERSONAL_API_KEY"
      }
    },
    "hetzner-ssh": {
      "enabled": true,
      "transport": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "mcp-server-ssh"
      ]
    },
    "resend": {
      "enabled": true,
      "transport": "stdio",
      "optional_env": [
        "SENDER_EMAIL_ADDRESS",
        "REPLY_TO_EMAIL_ADDRESSES"
      ],
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "resend-mcp"
      ],
      "env": {
        "RESEND_API_KEY": "${env:RESEND_API_KEY}",
        "SENDER_EMAIL_ADDRESS": "${env:RESEND_SENDER_EMAIL_ADDRESS}",
        "REPLY_TO_EMAIL_ADDRESSES": "${env:RESEND_REPLY_TO_EMAIL_ADDRESSES}"
      }
    },
    "chatgpt-fast": {
      "enabled": true,
      "transport": "stdio",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceRoot}\\scripts\\run-llm-mcp.ps1",
        "-Provider",
        "openai"
      ],
      "env": {
        "OPENAI_API_KEY": "${env:OPENAI_API_KEY}",
        "OPENAI_MODEL": "gpt-5.3-chat-latest"
      }
    },
    "chatgpt-latest": {
      "enabled": true,
      "transport": "stdio",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceRoot}\\scripts\\run-llm-mcp.ps1",
        "-Provider",
        "openai"
      ],
      "env": {
        "OPENAI_API_KEY": "${env:OPENAI_API_KEY}",
        "OPENAI_MODEL": "gpt-5.4"
      }
    },
    "claude-fast": {
      "enabled": true,
      "transport": "stdio",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceRoot}\\scripts\\run-llm-mcp.ps1",
        "-Provider",
        "anthropic"
      ],
      "env": {
        "ANTHROPIC_API_KEY": "${env:ANTHROPIC_API_KEY}",
        "ANTHROPIC_MODEL": "claude-haiku-4-5-20251001"
      }
    },
    "claude-latest": {
      "enabled": true,
      "transport": "stdio",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceRoot}\\scripts\\run-llm-mcp.ps1",
        "-Provider",
        "anthropic"
      ],
      "env": {
        "ANTHROPIC_API_KEY": "${env:ANTHROPIC_API_KEY}",
        "ANTHROPIC_MODEL": "claude-sonnet-4-6"
      }
    },
    "gemini-fast": {
      "enabled": true,
      "transport": "stdio",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceRoot}\\scripts\\run-llm-mcp.ps1",
        "-Provider",
        "gemini"
      ],
      "env": {
        "GEMINI_API_KEY": "${env:GEMINI_API_KEY}",
        "GEMINI_MODEL": "gemini-2.5-flash"
      }
    },
    "gemini-latest": {
      "enabled": true,
      "transport": "stdio",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceRoot}\\scripts\\run-llm-mcp.ps1",
        "-Provider",
        "gemini"
      ],
      "env": {
        "GEMINI_API_KEY": "${env:GEMINI_API_KEY}",
        "GEMINI_MODEL": "gemini-3.1-pro-preview"
      }
    },
    "grok-fast": {
      "enabled": true,
      "transport": "stdio",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceRoot}\\scripts\\run-llm-mcp.ps1",
        "-Provider",
        "xai"
      ],
      "env": {
        "XAI_API_KEY": "${env:XAI_API_KEY}",
        "GROK_MODEL": "grok-4.20-reasoning"
      }
    },
    "grok-latest": {
      "enabled": true,
      "transport": "stdio",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceRoot}\\scripts\\run-llm-mcp.ps1",
        "-Provider",
        "xai"
      ],
      "env": {
        "XAI_API_KEY": "${env:XAI_API_KEY}",
        "GROK_MODEL": "grok-4.20-reasoning"
      }
    }
  }
}
