{
  "version": 1,
  "servers": {
    "work-global": {
      "enabled": true,
      "transport": "stdio",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceRoot}\\scripts\\run-filesystem-mcp.ps1"
      ]
    },
    "canva": {
      "enabled": true,
      "transport": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "mcp-remote@latest",
        "https://mcp.canva.com/mcp"
      ]
    },
    "awarewave-ops": {
      "enabled": true,
      "transport": "stdio",
      "command": "node",
      "args": [
        "${workspaceRoot}\\mcp-local-wrappers\\awarewave-ops-mcp.mjs"
      ]
    },
    "copilot": {
      "enabled": true,
      "transport": "http",
      "url": "https://api.githubcopilot.com/mcp",
      "headers": {
        "Authorization": "Bearer ${env:COPILOT_MCP_BEARER_TOKEN}"
      },
      "codex": {
        "bearer_token_env_var": "COPILOT_MCP_BEARER_TOKEN"
      },
      "clients": {
        "copilot": {
          "exclude": true
        }
      }
    },
    "github": {
      "enabled": true,
      "transport": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      },
      "clients": {
        "copilot": {
          "exclude": true
        }
      }
    },
    "airtable": {
      "enabled": true,
      "transport": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@loticdigital/airtable-mcp-server"
      ],
      "env": {
        "AIRTABLE_API_KEY": "${env:AIRTABLE_API_KEY}"
      }
    },
    "replicate": {
      "enabled": true,
      "transport": "stdio",
      "optional_env": [
        "REPLICATE_WEBHOOK_SIGNING_KEY"
      ],
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "replicate-mcp"
      ],
      "env": {
        "REPLICATE_API_TOKEN": "${env:REPLICATE_API_TOKEN}",
        "REPLICATE_WEBHOOK_SIGNING_KEY": "${env:REPLICATE_WEBHOOK_SIGNING_KEY}"
      }
    },
    "perplexity": {
      "enabled": true,
      "transport": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@perplexity-ai/mcp-server"
      ],
      "env": {
        "PERPLEXITY_API_KEY": "${env:PERPLEXITY_API_KEY}"
      }
    },
    "wordpress": {
      "enabled": true,
      "transport": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@automattic/mcp-wordpress-remote@latest"
      ],
      "env": {
        "WP_API_URL": "${env:WP_API_URL}",
        "JWT_TOKEN": "${env:WORDPRESS_JWT_TOKEN}"
      }
    },
    "n8n": {
      "enabled": true,
      "transport": "http",
      "url": "${env:N8N_MCP_URL}",
      "headers": {
        "Authorization": "Bearer ${env:N8N_AUTH_BEARER_TOKEN}"
      },
      "codex": {
        "bearer_token_env_var": "N8N_AUTH_BEARER_TOKEN"
      }
    },
    "trigger": {
      "enabled": true,
      "transport": "stdio",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceRoot}\\scripts\\start-trigger-mcp.ps1",
        "-ProjectRef",
        "${env:TRIGGER_PROJECT_REF}"
      ],
      "env": {
        "TRIGGER_API_URL": "${env:TRIGGER_API_URL}"
      }
    },
    "supabase-b-postgres": {
      "enabled": true,
      "transport": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@modelcontextprotocol/server-postgres",
        "${env:SUPABASE_B_POSTGRES_DSN}"
      ],
      "note": "Requires SSH tunnel: scripts/open-supabase-ssh-tunnel.ps1 -Background"
    },
    "supabase": {
      "enabled": true,
      "transport": "http",
      "url": "${env:SUPABASE_MCP_URL}",
      "headers": {
        "Authorization": "Bearer ${env:SUPABASE_AUTH_BEARER_TOKEN}"
      },
      "codex": {
        "bearer_token_env_var": "SUPABASE_AUTH_BEARER_TOKEN"
      },
      "clients": {
        "codex": {
          "exclude": true
        }
      }
    },
    "supabase-a": {
      "enabled": true,
      "transport": "http",
      "url": "${env:SUPABASE_A_MCP_URL}",
      "headers": {
        "Authorization": "Bearer ${env:SUPABASE_A_AUTH_BEARER_TOKEN}"
      }
    },
    "cloudflare": {
      "enabled": true,
      "transport": "http",
      "url": "${env:CLOUDFLARE_MCP_URL}",
      "headers": {
        "Authorization": "Bearer ${env:CLOUDFLARE_AUTH_BEARER_TOKEN}"
      },
      "codex": {
        "bearer_token_env_var": "CLOUDFLARE_AUTH_BEARER_TOKEN"
      }
    },
    "posthog": {
      "enabled": true,
      "transport": "http",
      "url": "${env:POSTHOG_MCP_URL}",
      "headers": {
        "Authorization": "Bearer ${env:POSTHOG_API_KEY}"
      },
      "codex": {
        "bearer_token_env_var": "POSTHOG_API_KEY"
      }
    },
    "resend": {
      "enabled": true,
      "transport": "stdio",
      "optional_env": [
        "SENDER_EMAIL_ADDRESS",
        "REPLY_TO_EMAIL_ADDRESSES"
      ],
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "resend-mcp"
      ],
      "env": {
        "RESEND_API_KEY": "${env:RESEND_API_KEY}",
        "SENDER_EMAIL_ADDRESS": "${env:RESEND_SENDER_EMAIL_ADDRESS}",
        "REPLY_TO_EMAIL_ADDRESSES": "${env:RESEND_REPLY_TO_EMAIL_ADDRESSES}"
      }
    },
    "chatgpt-fast": {
      "enabled": true,
      "transport": "stdio",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceRoot}\\scripts\\run-llm-mcp.ps1",
        "-Provider",
        "openai"
      ],
      "env": {
        "OPENAI_API_KEY": "${env:OPENAI_API_KEY}",
        "OPENAI_MODEL": "gpt-5.3-chat-latest"
      }
    },
    "chatgpt-latest": {
      "enabled": true,
      "transport": "stdio",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceRoot}\\scripts\\run-llm-mcp.ps1",
        "-Provider",
        "openai"
      ],
      "env": {
        "OPENAI_API_KEY": "${env:OPENAI_API_KEY}",
        "OPENAI_MODEL": "gpt-5.4"
      }
    },
    "claude-fast": {
      "enabled": true,
      "transport": "stdio",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceRoot}\\scripts\\run-llm-mcp.ps1",
        "-Provider",
        "anthropic"
      ],
      "env": {
        "ANTHROPIC_API_KEY": "${env:ANTHROPIC_API_KEY}",
        "ANTHROPIC_MODEL": "claude-haiku-4-5-20251001"
      }
    },
    "claude-latest": {
      "enabled": true,
      "transport": "stdio",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceRoot}\\scripts\\run-llm-mcp.ps1",
        "-Provider",
        "anthropic"
      ],
      "env": {
        "ANTHROPIC_API_KEY": "${env:ANTHROPIC_API_KEY}",
        "ANTHROPIC_MODEL": "claude-sonnet-4-6"
      }
    },
    "gemini-fast": {
      "enabled": true,
      "transport": "stdio",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceRoot}\\scripts\\run-llm-mcp.ps1",
        "-Provider",
        "gemini"
      ],
      "env": {
        "GEMINI_API_KEY": "${env:GEMINI_API_KEY}",
        "GEMINI_MODEL": "gemini-2.5-flash"
      }
    },
    "gemini-latest": {
      "enabled": true,
      "transport": "stdio",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceRoot}\\scripts\\run-llm-mcp.ps1",
        "-Provider",
        "gemini"
      ],
      "env": {
        "GEMINI_API_KEY": "${env:GEMINI_API_KEY}",
        "GEMINI_MODEL": "gemini-3.1-pro-preview"
      }
    }
  }
}
