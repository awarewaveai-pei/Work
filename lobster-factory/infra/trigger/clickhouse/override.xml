<?xml version="1.0"?>
<clickhouse>
  <!-- v4 Goose migrations (e.g. task_runs_v1) use JSON columns; CH 24.x requires this -->
  <profiles>
    <default>
      <allow_experimental_json_type>1</allow_experimental_json_type>
    </default>
  </profiles>

  <!--
    Docker mem_limit for clickhouse service = 2048m.
    Internal cap is set to ~1.6 GiB (1717986918 bytes) to leave ~400 MiB headroom
    for OS page cache and Docker overhead.

    History: originally set to 800 MB (800000000) which was too low once
    ClickHouse system logs accumulate — trace_log alone grew to 324 MiB,
    text_log to 263 MiB, causing RSS to exceed the cap and trigger
    MEMORY_LIMIT_EXCEEDED on every trigger-webapp startup (crash-loop).
    Raised 2026-04-29.

    TTL policies below keep system logs bounded by retention windows so RSS
    does not creep up without action.
  -->
  <max_server_memory_usage>1717986918</max_server_memory_usage>

  <!-- ── System log TTL: tiered retention policy ──────────────────────────
       Rationale:
         7d  — high-volume traces/metrics (replaced by Netdata for long-term)
         14d — query & text logs (useful for post-incident perf regression)
         30d — error log (recurring / rare bugs need a month of history)
  ──────────────────────────────────────────────────────────────────────── -->
  <trace_log>
    <ttl>event_date + INTERVAL 7 DAY DELETE</ttl>
  </trace_log>
  <metric_log>
    <ttl>event_date + INTERVAL 7 DAY DELETE</ttl>
  </metric_log>
  <asynchronous_metric_log>
    <ttl>event_date + INTERVAL 7 DAY DELETE</ttl>
  </asynchronous_metric_log>
  <processors_profile_log>
    <ttl>event_date + INTERVAL 7 DAY DELETE</ttl>
  </processors_profile_log>
  <text_log>
    <ttl>event_date + INTERVAL 14 DAY DELETE</ttl>
  </text_log>
  <query_log>
    <ttl>event_date + INTERVAL 14 DAY DELETE</ttl>
  </query_log>
  <error_log>
    <ttl>event_date + INTERVAL 30 DAY DELETE</ttl>
  </error_log>
</clickhouse>