# Trigger.dev self-hosted — copy to .env on the VPS, never commit .env
#
# Generate secrets:
#   openssl rand -hex 32   → for SESSION_SECRET, MAGIC_LINK_SECRET,
#                             COORDINATOR_SECRET, PROVIDER_SECRET
#   openssl rand -hex 16   → for ENCRYPTION_KEY (must be exactly 32 hex chars = 16 bytes)
#   openssl rand -base64 24 → for TRIGGER_DB_PASSWORD, TRIGGER_REDIS_PASSWORD

# ── Postgres ──────────────────────────────────────────────────
TRIGGER_DB_PASSWORD=change_this_strong_password

# ── Redis ─────────────────────────────────────────────────────
TRIGGER_REDIS_PASSWORD=change_this_redis_password

# ── Webapp secrets (generate each with: openssl rand -hex 32) ─
TRIGGER_SESSION_SECRET=replace_with_openssl_rand_hex_32
TRIGGER_MAGIC_LINK_SECRET=replace_with_openssl_rand_hex_32

# Exactly 32 hex chars (openssl rand -hex 16)
TRIGGER_ENCRYPTION_KEY=replace_with_openssl_rand_hex_16

# ── Coordinator ↔ Docker provider (must match in both services) ─
TRIGGER_COORDINATOR_SECRET=replace_with_openssl_rand_hex_32
TRIGGER_PROVIDER_SECRET=replace_with_openssl_rand_hex_32
