# Trigger.dev v4 self-host — copy to .env on the VPS（勿提交 .env）
# 官方參考：https://github.com/triggerdotdev/trigger.dev/tree/main/hosting/docker
# 環境變數說明：https://trigger.dev/docs/self-hosting/env/webapp
#
# 與舊版（單一 webapp + docker provider）相比：本檔變數命名對齊官方 v4。
# 若你舊 .env 使用 TRIGGER_SESSION_SECRET 等，請改為下列對應欄位並重新 up。

# ── 映像標籤（與 packages/workflows 的 @trigger.dev/sdk 大版對齊）────
TRIGGER_IMAGE_TAG=v4.4.4

# ── Postgres（v4 預設 DB 名多為 main）──────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_this_strong_password
POSTGRES_DB=main
POSTGRES_IMAGE_TAG=16

# Prisma 慣用連線字串（webapp / electric 共用）
DATABASE_URL=postgresql://postgres:change_this_strong_password@postgres:5432/main?schema=public&sslmode=disable
DIRECT_URL=postgresql://postgres:change_this_strong_password@postgres:5432/main?schema=public&sslmode=disable

# ── Redis（本 compose 使用無密碼內網 Redis；勿對公網暴露）────────
REDIS_IMAGE_TAG=7-alpine

# ── ClickHouse（v4 硬性依賴）──────────────────────────────────
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=change_this_clickhouse_password
# 必須可被 webapp 容器解析；?secure=false 降低與舊版 client 參數衝突。
# 使用 ClickHouse 25.3+（見 CLICKHOUSE_IMAGE_TAG）：勿再加 allow_experimental_json_type（Trigger webapp 會校驗 URL 參數並拒絕未知鍵）。
CLICKHOUSE_URL=http://default:change_this_clickhouse_password@clickhouse:8123?secure=false
RUN_REPLICATION_CLICKHOUSE_URL=http://default:change_this_clickhouse_password@clickhouse:8123
# 固定版本，避免 latest 漂移造成設定不相容（例如 latency_log 已移除）。
# Trigger.dev v4.4.x Goose migration 003 需要 MergeTree「enable_json_type」（ClickHouse ≥25.3）；勿低於此線。
CLICKHOUSE_IMAGE_TAG=25.7.5-debian-12-r0

# ── 內建 Docker Registry（task 映像 push/pull）──────────────────
# 內網 hostname = compose service 名「registry」；勿加 http://
DOCKER_REGISTRY_URL=registry:5000
DEPLOY_REGISTRY_NAMESPACE=trigger
# 必須與 registry/auth.htpasswd 內帳密一致（預設檔為官方範例帳號）
DEPLOY_REGISTRY_USERNAME=registry-user
DEPLOY_REGISTRY_PASSWORD=change_this_registry_password

# ── MinIO（物件儲存；預設會建 packets bucket）──────────────────
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=change_this_minio_password
MINIO_IMAGE_TAG=latest
OBJECT_STORE_BASE_URL=http://minio:9000
OBJECT_STORE_BUCKET=packets
OBJECT_STORE_ACCESS_KEY_ID=admin
OBJECT_STORE_SECRET_ACCESS_KEY=change_this_minio_password
OBJECT_STORE_SERVICE=s3

# Deployment artifact upload bucket (v4 /api/v1/artifacts)
ARTIFACTS_OBJECT_STORE_BASE_URL=http://minio:9000
ARTIFACTS_OBJECT_STORE_BUCKET=packets
ARTIFACTS_OBJECT_STORE_ACCESS_KEY_ID=admin
ARTIFACTS_OBJECT_STORE_SECRET_ACCESS_KEY=change_this_minio_password
ARTIFACTS_OBJECT_STORE_REGION=us-east-1

# ── Webapp 公開 URL（請改成你的網域；需與 Nginx server_name 一致）──
APP_ORIGIN=https://trigger.aware-wave.com
LOGIN_ORIGIN=https://trigger.aware-wave.com
API_ORIGIN=https://trigger.aware-wave.com
STREAM_ORIGIN=https://trigger.aware-wave.com
# 給容器內 OTEL 用；通常同網域 /otel
DEV_OTEL_EXPORTER_OTLP_ENDPOINT=https://trigger.aware-wave.com/otel

# ── Webapp secrets（官方建議 openssl rand -hex 16）─────────────
SESSION_SECRET=replace_with_openssl_rand_hex_16
MAGIC_LINK_SECRET=replace_with_openssl_rand_hex_16
# 必須為 32 個 hex 字元（openssl rand -hex 16）
ENCRYPTION_KEY=replace_with_openssl_rand_hex_16

# Webapp ↔ Supervisor 共用（請改成強隨機；兩邊必須相同）
MANAGED_WORKER_SECRET=replace_with_openssl_rand_hex_32

# ── Supervisor / worker ───────────────────────────────────────
# 首次啟動由 webapp bootstrap 寫入 shared volume；可留預設讀檔案
TRIGGER_WORKER_TOKEN=file:///home/node/shared/worker_token
TRIGGER_API_URL=http://webapp:3000
OTEL_EXPORTER_OTLP_ENDPOINT=http://webapp:3000/otel
SUPERVISOR_DEBUG=0

# ── 與 phase1 Nginx 同一張 Docker 網路（external）───────────────
# 若 `docker network ls` 顯示的不是 lobster-net，請改成實際名稱
LOBSTER_DOCKER_NETWORK=lobster-net

# ── 僅本機除錯用 publish IP（預設 127.0.0.1）────────────────────
WEBAPP_PUBLISH_IP=127.0.0.1
CLICKHOUSE_PUBLISH_IP=127.0.0.1
REGISTRY_PUBLISH_IP=127.0.0.1
MINIO_PUBLISH_IP=127.0.0.1

# ── 可選 ───────────────────────────────────────────────────────
# Workflow-side Sentry DSN naming（給 packages/workflows）：
# 建議在 Trigger dashboard 的 project env 設定下列 key（新命名優先）：
# SENTRY_DSN_TRIGGER_WORKFLOWS > LOBSTER_SENTRY_DSN > TRIGGER_SENTRY_DSN > SENTRY_DSN
# SENTRY_DSN_TRIGGER_WORKFLOWS=
ELECTRIC_IMAGE_TAG=1.2.4
DOCKER_PROXY_IMAGE_TAG=latest
APP_LOG_LEVEL=info
CLICKHOUSE_LOG_LEVEL=info
RUN_REPLICATION_ENABLED=1
RUN_REPLICATION_LOG_LEVEL=info
INTERNAL_OTEL_TRACE_LOGGING_ENABLED=0
TRIGGER_BOOTSTRAP_WORKER_GROUP_NAME=bootstrap
NODE_MAX_OLD_SPACE_SIZE=1024
