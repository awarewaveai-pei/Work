# Copy to .env on the server — never commit .env
#
# N8N_HOST = public hostname or IP users type in browser (no scheme)
N8N_HOST=YOUR_VPS_IP_OR_DOMAIN
N8N_WEBHOOK_URL=http://YOUR_VPS_IP_OR_DOMAIN/n8n/

WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wpuser
WORDPRESS_DB_PASSWORD=change_this_wp_password
WORDPRESS_DB_ROOT_PASSWORD=change_this_root_password

# Must match how browsers reach WordPress (subdir install behind Nginx). No trailing slash.
WORDPRESS_PUBLIC_URL=http://YOUR_VPS_IP_OR_DOMAIN/wp

# Self-hosted Supabase API (example port 8000 — match your install)
SUPABASE_URL=http://YOUR_VPS_IP_OR_DOMAIN:8000
SUPABASE_SERVICE_ROLE_KEY=replace_with_your_service_role_key

NEXT_PUBLIC_SUPABASE_URL=http://YOUR_VPS_IP_OR_DOMAIN:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_with_your_anon_key

# Used by Next.js server components to call node-api inside Docker network
INTERNAL_API_BASE_URL=http://node-api:3001

OPENAI_API_KEY=replace_with_your_openai_api_key

# Optional: backup-phase1.sh output directory
# BACKUP_DIR=/var/backups/lobster-phase1
