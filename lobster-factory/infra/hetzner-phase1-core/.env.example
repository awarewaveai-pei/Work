# Copy to .env on the server — never commit .env
#
# 「本機 .env.local vs 伺服器 .env」怎麼統一腦內模型 — 只認一份（輪替步驟）：
#   agency-os/docs/operations/hetzner-self-host-start-here.md → 環境變數唯一對照
#
# N8N_HOST = public hostname or IP users type in browser (no scheme)
N8N_HOST=YOUR_VPS_IP_OR_DOMAIN
N8N_WEBHOOK_URL=http://YOUR_VPS_IP_OR_DOMAIN/n8n/

# --- n8n URL layout (pick ONE; must match reverse proxy) ---
# Long-form matrix + MCP smoke TRY_ALT: agency-os/docs/operations/n8n-self-hosted-mcp-troubleshooting.md
# Pattern A — apex path /n8n/ (nginx snippets/lobster-aware-wave-locations.inc):
#   N8N_PATH=/n8n/   (compose default)
#   N8N_WEBHOOK_URL=https://aware-wave.com/n8n/
#   MCP URL for Cursor: https://aware-wave.com/n8n/mcp-server/http
# Pattern B — dedicated hostname n8n.aware-wave.com (apache/sites-available/n8n.conf, ProxyPass / → 5678):
#   N8N_PATH=/
#   N8N_HOST=n8n.aware-wave.com
#   N8N_WEBHOOK_URL=https://n8n.aware-wave.com/
#   MCP URL for Cursor: https://n8n.aware-wave.com/mcp-server/http

# n8n image tag — use explicit semver or digest in production (see LONG_TERM_OPS.md).
N8N_IMAGE_TAG=2.18.5

WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wpuser
WORDPRESS_DB_PASSWORD=change_this_wp_password
WORDPRESS_DB_ROOT_PASSWORD=change_this_root_password

# Public origin for WordPress (root install behind Nginx). No trailing slash.
WORDPRESS_PUBLIC_URL=http://YOUR_VPS_IP_OR_DOMAIN

# Self-hosted Supabase API. If the caller runs on the host, localhost/127.0.0.1 is fine.
# If the caller runs inside Docker, localhost points at the container itself, so use a host-reachable address instead.
SUPABASE_URL=http://127.0.0.1:8000
SUPABASE_SERVICE_ROLE_KEY=replace_with_your_service_role_key

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_with_your_anon_key

# Used by Next.js server components to call node-api inside Docker network
INTERNAL_API_BASE_URL=http://node-api:3001

# --- Ops Inbox (next-admin Path B) — optional until you wire webhooks / Slack / Gemini ---
# Bearer token for POST /api/webhooks/* (Authorization: Bearer …). Required for ingest in production.
OPS_INBOX_INGEST_TOKEN=
# Set to "true" to allow Slack incident notifications (needs OPS_INBOX_SLACK_INCIDENTS_WEBHOOK).
OPS_INBOX_NOTIFY_ENABLED=
# Incoming Slack webhook URL (incoming webhook app); keep server-only.
OPS_INBOX_SLACK_INCIDENTS_WEBHOOK=
# Public base URL of next-admin (no trailing slash); used in Slack links. Example: https://app.aware-wave.com
OPS_INBOX_PUBLIC_URL=
# Set to "true" to accept PostHog webhook payloads at /api/webhooks/posthog
OPS_INBOX_POSTHOG_ENABLED=
# Set to "true" to enable Gemini auto-classify path; requires GEMINI_API_KEY
OPS_INBOX_GEMINI_ENABLED=
OPS_INBOX_GEMINI_DAILY_LIMIT=1400
GEMINI_API_KEY=
# Shared secret for edge/reverse proxy to pass x-ops-proxy-auth (middleware). Required in production for trusted role headers.
OPS_PROXY_SHARED_SECRET=
# Leave empty for defaults; set OPS_ALLOW_SIMULATED_ROLE_FALLBACK=false to hard-disable simulated roles in prod.
OPS_ALLOW_SIMULATED_ROLE_FALLBACK=
# e.g. header | jwt — see lib/ops-role.ts
OPS_ROLE_RESOLUTION_MODE=
# Optional base for ops-console deep links (no trailing slash)
INTERNAL_ADMIN_BASE_URL=

OPENAI_API_KEY=replace_with_your_openai_api_key

# Sentry error tracking (recommended split-by-service; can point to same DSN if you want fewer projects)
# node-api (captures Supabase integration failures from node-api route handlers)
SENTRY_DSN_NODE_API=
# Trigger.dev workflows (set in Trigger project/env; local fallback can also read this key)
SENTRY_DSN_TRIGGER_WORKFLOWS=
# n8n backend (preferred explicit key; compose also supports N8N_SENTRY_DSN and legacy SENTRY_DSN_N8N)
SENTRY_DSN_N8N_BACKEND=
# n8n editor/frontend (optional; browser-side errors)
SENTRY_DSN_N8N_FRONTEND=
# Next.js admin frontend
SENTRY_DSN_NEXT_ADMIN=
# PostHog (cloud; optional — leave empty to disable client analytics)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# WordPress/PHP
SENTRY_DSN_WORDPRESS=

# Backward-compatible aliases (keep empty unless old scripts still read them)
SENTRY_DSN=
SENTRY_DSN_WP=
SENTRY_DSN_NEXT=

# Sentry — self-hosted n8n (backend + optional editor frontend)
# Create a Node.js (or dedicated) project in Sentry; leave empty to disable.
# Preferred key used directly by docker-compose.yml:
N8N_SENTRY_DSN=
# Preferred cross-stack alias for backend split:
SENTRY_DSN_N8N_BACKEND=
# Backward-compatible alias (older docs/scripts):
SENTRY_DSN_N8N=
# Optional: browser/editor errors; can be a separate Browser JS DSN or leave empty.
SENTRY_DSN_N8N_FRONTEND=
# Tags sent with n8n Sentry events (backend uses ENVIRONMENT / DEPLOYMENT_NAME in n8n)
N8N_SENTRY_ENVIRONMENT=staging
N8N_DEPLOYMENT_NAME=lobster-phase1-n8n
# 0 = traces/profiles off (recommended until you need performance data)
N8N_SENTRY_TRACES_SAMPLE_RATE=0
N8N_SENTRY_PROFILES_SAMPLE_RATE=0

# Grafana admin credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_this_grafana_password

# Resend email API
RESEND_API_KEY=

# Slack notifications (Uptime Kuma alerts + app use)
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=

# Optional: backup-phase1.sh output directory
# BACKUP_DIR=/var/backups/lobster-phase1
