# Copy to .env on the server — never commit .env
#
# 「本機 .env.local vs 伺服器 .env」怎麼統一腦內模型 — 只認一份（輪替步驟）：
#   agency-os/docs/operations/hetzner-self-host-start-here.md → 環境變數唯一對照
#
# N8N_HOST = public hostname or IP users type in browser (no scheme)
N8N_HOST=YOUR_VPS_IP_OR_DOMAIN
N8N_WEBHOOK_URL=http://YOUR_VPS_IP_OR_DOMAIN/n8n/

# n8n image tag — use explicit semver or digest in production (see LONG_TERM_OPS.md).
N8N_IMAGE_TAG=2.15.1

WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wpuser
WORDPRESS_DB_PASSWORD=change_this_wp_password
WORDPRESS_DB_ROOT_PASSWORD=change_this_root_password

# Public origin for WordPress (root install behind Nginx). No trailing slash.
WORDPRESS_PUBLIC_URL=http://YOUR_VPS_IP_OR_DOMAIN

# Self-hosted Supabase API (example port 8000 — match your install)
SUPABASE_URL=http://YOUR_VPS_IP_OR_DOMAIN:8000
SUPABASE_SERVICE_ROLE_KEY=replace_with_your_service_role_key

NEXT_PUBLIC_SUPABASE_URL=http://YOUR_VPS_IP_OR_DOMAIN:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_with_your_anon_key

# Used by Next.js server components to call node-api inside Docker network
INTERNAL_API_BASE_URL=http://node-api:3001

OPENAI_API_KEY=replace_with_your_openai_api_key

# Sentry error tracking (recommended split-by-service; can point to same DSN if you want fewer projects)
# node-api (captures Supabase integration failures from node-api route handlers)
SENTRY_DSN_NODE_API=
# Trigger.dev workflows (set in Trigger project/env; local fallback can also read this key)
SENTRY_DSN_TRIGGER_WORKFLOWS=
# n8n backend (preferred explicit key; compose also supports N8N_SENTRY_DSN and legacy SENTRY_DSN_N8N)
SENTRY_DSN_N8N_BACKEND=
# n8n editor/frontend (optional; browser-side errors)
SENTRY_DSN_N8N_FRONTEND=
# Next.js admin frontend
SENTRY_DSN_NEXT_ADMIN=
# PostHog (cloud; optional — leave empty to disable client analytics)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# WordPress/PHP
SENTRY_DSN_WORDPRESS=

# Backward-compatible aliases (keep empty unless old scripts still read them)
SENTRY_DSN=
SENTRY_DSN_WP=
SENTRY_DSN_NEXT=

# Sentry — self-hosted n8n (backend + optional editor frontend)
# Create a Node.js (or dedicated) project in Sentry; leave empty to disable.
# Preferred key used directly by docker-compose.yml:
N8N_SENTRY_DSN=
# Preferred cross-stack alias for backend split:
SENTRY_DSN_N8N_BACKEND=
# Backward-compatible alias (older docs/scripts):
SENTRY_DSN_N8N=
# Optional: browser/editor errors; can be a separate Browser JS DSN or leave empty.
SENTRY_DSN_N8N_FRONTEND=
# Tags sent with n8n Sentry events (backend uses ENVIRONMENT / DEPLOYMENT_NAME in n8n)
N8N_SENTRY_ENVIRONMENT=staging
N8N_DEPLOYMENT_NAME=lobster-phase1-n8n
# 0 = traces/profiles off (recommended until you need performance data)
N8N_SENTRY_TRACES_SAMPLE_RATE=0
N8N_SENTRY_PROFILES_SAMPLE_RATE=0

# Optional: backup-phase1.sh output directory
# BACKUP_DIR=/var/backups/lobster-phase1
