# Staging environment — copy to .env.staging on VPS, fill in real values.
# Never commit .env.staging.
#
# Used with:
#   docker compose -p lobster-staging --env-file .env.staging \
#     -f docker-compose.yml -f docker-compose.staging.yml ...
#
# Mirror .env.example structure; use staging-specific credentials and URLs.
# Sentry environment tags must be "staging" (already default in n8n compose).

# --- n8n ---
N8N_HOST=YOUR_VPS_IP_OR_DOMAIN
N8N_WEBHOOK_URL=http://YOUR_VPS_IP_OR_DOMAIN/n8n/
N8N_PATH=/n8n/
N8N_IMAGE_TAG=2.18.5

# --- WordPress ---
WORDPRESS_DB_NAME=wordpress_staging
WORDPRESS_DB_USER=wpuser_staging
WORDPRESS_DB_PASSWORD=change_this_staging_wp_password
WORDPRESS_DB_ROOT_PASSWORD=change_this_staging_root_password
WORDPRESS_PUBLIC_URL=http://YOUR_VPS_IP_OR_DOMAIN

# --- Supabase (prefer a dedicated staging project to avoid polluting prod data) ---
SUPABASE_URL=http://127.0.0.1:8000
SUPABASE_SERVICE_ROLE_KEY=replace_with_staging_service_role_key
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_with_staging_anon_key

INTERNAL_API_BASE_URL=http://node-api:3001

# --- Ops Inbox (staging — can leave empty until wired) ---
OPS_INBOX_INGEST_TOKEN=
OPS_INBOX_NOTIFY_ENABLED=
OPS_INBOX_SLACK_INCIDENTS_WEBHOOK=
OPS_INBOX_PUBLIC_URL=
OPS_INBOX_POSTHOG_ENABLED=
OPS_INBOX_GEMINI_ENABLED=
OPS_INBOX_GEMINI_DAILY_LIMIT=1400
GEMINI_API_KEY=
OPS_PROXY_SHARED_SECRET=
OPS_ALLOW_SIMULATED_ROLE_FALLBACK=true
OPS_ROLE_RESOLUTION_MODE=
INTERNAL_ADMIN_BASE_URL=

OPENAI_API_KEY=replace_with_staging_openai_key

# --- Sentry (staging environment tag) ---
SENTRY_DSN_NODE_API=
SENTRY_DSN_N8N_BACKEND=
SENTRY_DSN_N8N_FRONTEND=
SENTRY_DSN_NEXT_ADMIN=
SENTRY_DSN_WORDPRESS=
N8N_SENTRY_DSN=
N8N_SENTRY_ENVIRONMENT=staging
N8N_DEPLOYMENT_NAME=lobster-phase1-n8n-staging
N8N_SENTRY_TRACES_SAMPLE_RATE=0
N8N_SENTRY_PROFILES_SAMPLE_RATE=0

# --- PostHog ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_this_grafana_staging_password

# --- Resend ---
RESEND_API_KEY=

# --- Slack ---
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=

# --- Backup directory (optional) ---
# BACKUP_DIR=/var/backups/lobster-phase1-staging
