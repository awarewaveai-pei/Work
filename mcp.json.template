{
  "mcpServers": {
    "wordpress": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@automattic/mcp-wordpress-remote@latest"
      ],
      "env": {
        "WP_API_URL": "https://YOUR_WORDPRESS_SITE/",
        "OAUTH_ENABLED": "false",
        "JWT_TOKEN": "<PASTE_WP_JWT_TOKEN_IF_USING_JWT>"
      }
    },
    "replicate": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "replicate-mcp"
      ],
      "env": {
        "REPLICATE_API_TOKEN": "<PASTE_REPLICATE_TOKEN>",
        "REPLICATE_WEBHOOK_SIGNING_KEY": "<PASTE_REPLICATE_WEBHOOK_SECRET>"
      }
    },
    "n8n": {
      "type": "http",
      "url": "https://YOUR_INSTANCE.app.n8n.cloud/mcp-server/http",
      "headers": {
        "Authorization": "Bearer <PASTE_N8N_MCP_BEARER>"
      }
    },
    "github": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "<PASTE_GITHUB_PAT>"
      }
    },
    "work-global": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "${userHome}",
        "${workspaceFolder}"
      ]
    },
    "chatgpt-fast": {
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/run-llm-mcp.ps1",
        "-Provider",
        "openai"
      ],
      "env": {
        "OPENAI_API_KEY": "<PASTE_OPENAI_KEY>",
        "OPENAI_MODEL": "gpt-5.3-chat-latest"
      }
    },
    "chatgpt-latest": {
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/run-llm-mcp.ps1",
        "-Provider",
        "openai"
      ],
      "env": {
        "OPENAI_API_KEY": "<PASTE_OPENAI_KEY>",
        "OPENAI_MODEL": "gpt-5.4"
      }
    },
    "claude-fast": {
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/run-llm-mcp.ps1",
        "-Provider",
        "anthropic"
      ],
      "env": {
        "ANTHROPIC_API_KEY": "<PASTE_ANTHROPIC_KEY>",
        "ANTHROPIC_MODEL": "claude-haiku-4-5-20251001"
      }
    },
    "claude-latest": {
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/run-llm-mcp.ps1",
        "-Provider",
        "anthropic"
      ],
      "env": {
        "ANTHROPIC_API_KEY": "<PASTE_ANTHROPIC_KEY>",
        "ANTHROPIC_MODEL": "claude-sonnet-4-6"
      }
    },
    "perplexity": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@perplexity-ai/mcp-server"
      ],
      "env": {
        "PERPLEXITY_API_KEY": "<PASTE_PERPLEXITY_KEY>"
      }
    },
    "gemini-fast": {
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/run-llm-mcp.ps1",
        "-Provider",
        "gemini"
      ],
      "env": {
        "GEMINI_API_KEY": "<PASTE_GEMINI_KEY>",
        "GEMINI_MODEL": "gemini-2.5-flash"
      }
    },
    "gemini-latest": {
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/run-llm-mcp.ps1",
        "-Provider",
        "gemini"
      ],
      "env": {
        "GEMINI_API_KEY": "<PASTE_GEMINI_KEY>",
        "GEMINI_MODEL": "gemini-3.1-pro-preview"
      }
    },
    "copilot": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp",
      "headers": {
        "Authorization": "Bearer ${env:COPILOT_MCP_BEARER_TOKEN}"
      }
    },
    "trigger": {
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/start-trigger-mcp.ps1",
        "-ProjectRef",
        "<PASTE_TRIGGER_PROJECT_REF>"
      ],
      "env": {
        "TRIGGER_API_URL": "https://YOUR_TRIGGER_PUBLIC_ORIGIN"
      }
    },
    "supabase-postgres": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@modelcontextprotocol/server-postgres",
        "${SUPABASE_POSTGRES_MCP_DSN}"
      ],
      "env": {
        "SUPABASE_URL": "${SUPABASE_URL}",
        "SUPABASE_ANON_KEY": "${SUPABASE_ANON_KEY}",
        "SUPABASE_SERVICE_ROLE_KEY": "${SUPABASE_SERVICE_ROLE_KEY}"
      }
    }
  }
}
