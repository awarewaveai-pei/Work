# Codex MCP — copy to `config.toml` in this folder (the real file is gitignored).
# Replace YOUR_* placeholders and paths; keep secrets in env vars or vault.

[mcp_servers.wordpress]
command = "cmd"
args = ["/c", "npx", "-y", "@automattic/mcp-wordpress-remote@latest"]
enabled = false

[mcp_servers.wordpress.env]
WP_API_URL = "https://YOUR_WORDPRESS_SITE/"
JWT_TOKEN = "${WP_APPLICATION_PASSWORD}"

[mcp_servers.replicate]
command = "cmd"
args = ["/c", "npx", "-y", "replicate-mcp"]
enabled = true

[mcp_servers.replicate.env]
REPLICATE_API_TOKEN = "${REPLICATE_API_TOKEN}"
REPLICATE_WEBHOOK_SIGNING_KEY = "${REPLICATE_WEBHOOK_SIGNING_KEY}"

[mcp_servers.n8n]
url = "https://YOUR_INSTANCE.app.n8n.cloud/mcp-server/http"
bearer_token_env_var = "N8N_MCP_BEARER_TOKEN"
enabled = false

[mcp_servers.github]
command = "cmd"
args = ["/c", "npx", "-y", "@modelcontextprotocol/server-github"]
enabled = true

[mcp_servers.github.env]
GITHUB_PERSONAL_ACCESS_TOKEN = "${GITHUB_TOKEN}"

[mcp_servers.work-global]
command = "cmd"
args = ["/c", "npx", "-y", "@modelcontextprotocol/server-filesystem", "C:\\Users\\YOUR_USER", "C:\\path\\to\\monorepo"]
enabled = true

[mcp_servers.chatgpt-fast]
command = "powershell"
args = ["-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "scripts/run-llm-mcp.ps1", "-Provider", "openai"]
enabled = true

[mcp_servers.chatgpt-fast.env]
OPENAI_API_KEY = "${OPENAI_API_KEY}"
OPENAI_MODEL = "gpt-5.3-chat-latest"

[mcp_servers.chatgpt-latest]
command = "powershell"
args = ["-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "scripts/run-llm-mcp.ps1", "-Provider", "openai"]
enabled = true

[mcp_servers.chatgpt-latest.env]
OPENAI_API_KEY = "${OPENAI_API_KEY}"
OPENAI_MODEL = "gpt-5.4"

[mcp_servers.claude-fast]
command = "powershell"
args = ["-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "scripts/run-llm-mcp.ps1", "-Provider", "anthropic"]
enabled = true

[mcp_servers.claude-fast.env]
ANTHROPIC_API_KEY = "${ANTHROPIC_API_KEY}"
ANTHROPIC_MODEL = "claude-haiku-4-5-20251001"

[mcp_servers.claude-latest]
command = "powershell"
args = ["-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "scripts/run-llm-mcp.ps1", "-Provider", "anthropic"]
enabled = true

[mcp_servers.claude-latest.env]
ANTHROPIC_API_KEY = "${ANTHROPIC_API_KEY}"
ANTHROPIC_MODEL = "claude-sonnet-4-6"

[mcp_servers.perplexity]
command = "cmd"
args = ["/c", "npx", "-y", "@perplexity-ai/mcp-server"]
enabled = true

[mcp_servers.perplexity.env]
PERPLEXITY_API_KEY = "${PERPLEXITY_API_KEY}"

[mcp_servers.gemini-fast]
command = "powershell"
args = ["-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "scripts/run-llm-mcp.ps1", "-Provider", "gemini"]
enabled = true

[mcp_servers.gemini-fast.env]
GEMINI_API_KEY = "${GEMINI_API_KEY}"
GEMINI_MODEL = "gemini-2.5-flash"

[mcp_servers.gemini-latest]
command = "powershell"
args = ["-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "scripts/run-llm-mcp.ps1", "-Provider", "gemini"]
enabled = true

[mcp_servers.gemini-latest.env]
GEMINI_API_KEY = "${GEMINI_API_KEY}"
GEMINI_MODEL = "gemini-3.1-pro-preview"

[mcp_servers.copilot]
url = "https://api.githubcopilot.com/mcp/"
bearer_token_env_var = "COPILOT_AUTH_BEARER_TOKEN"
enabled = false

[mcp_servers.trigger]
command = "powershell"
args = ["-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "scripts/start-trigger-mcp.ps1"]
enabled = false

[mcp_servers.trigger.env]
TRIGGER_PROJECT_REF = "${TRIGGER_PROJECT_REF}"

[mcp_servers.supabase]
url = "https://mcp.supabase.com/mcp?project_ref=YOUR_PROJECT_REF&read_only=true&features=database,docs,development,debugging"
enabled = false
