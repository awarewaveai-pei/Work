# 複製為本機或伺服器上的 .env（勿提交 git）
# 變數名請以 Supabase / Trigger / n8n / MinIO 官方 self-host 範本為準，此檔僅提醒「類型」。
#
# Phase 1「邊緣棧」實際 .env 範本（Nginx / Redis / n8n / WordPress / Node API / Next Admin；Supabase 另機）：
#   lobster-factory/infra/hetzner-phase1-core/.env.example
# 全堆疊順序／平面／進度（單一索引，變更時同步 CHANGE_IMPACT_MATRIX）：
#   agency-os/docs/operations/hetzner-stack-rollout-index.md

# --- Supabase（自架）---
# POSTGRES_PASSWORD=
# JWT_SECRET=
# ANON_KEY=
# SERVICE_ROLE_KEY=
# SITE_URL=https://your-project.example.com

# --- S3 / MinIO（Storage）---
# S3_ENDPOINT=https://minio.example.com
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=

# --- Redis ---
# REDIS_URL=redis://:password@redis:6379

# --- Trigger.dev（自架；名稱依官方模板）---
# TRIGGER_*

# --- n8n ---
# N8N_ENCRYPTION_KEY=
# DB_TYPE=postgresdb
# DB_POSTGRESDB_HOST=
# DB_POSTGRESDB_DATABASE=
# DB_POSTGRESDB_USER=
# DB_POSTGRESDB_PASSWORD=
# WEBHOOK_URL=https://n8n.example.com/

# --- Node API（RAG / BFF）---
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# EMBEDDING_API_KEY=
# OPENAI_API_KEY=

# --- WordPress（若用 env 注入）---
# WORDPRESS_DB_HOST=
# WORDPRESS_DB_NAME=
# WORDPRESS_DB_USER=
# WORDPRESS_DB_PASSWORD=
