{
    "mcpServers":  {
                       "posthog":  {
                                       "url":  "https://mcp.posthog.com/mcp",
                                       "headers":  {
                                                       "Authorization":  "Bearer ${env:POSTHOG_PERSONAL_API_KEY}"
                                                   },
                                       "type":  "http"
                                   },
                       "copilot":  {
                                       "url":  "https://api.githubcopilot.com/mcp",
