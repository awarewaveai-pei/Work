# Monorepo 根目錄：複製為 `.env.local`（勿提交 `.env.local`）
#
# 環境變數「放哪幾個檔、輪替時怎麼同步」——只認一份說明：
#   agency-os/docs/operations/hetzner-self-host-start-here.md → 章節「環境變數唯一對照」
#
# 本檔供根目錄 RAG 腳本使用（npm run rag:setup / rag:embed / rag:query）。

SUPABASE_URL=http://127.0.0.1:8000
SUPABASE_SERVICE_ROLE_KEY=replace_with_service_role_key
OPENAI_API_KEY=replace_with_openai_key

# 選用
# EMBEDDING_MODEL=text-embedding-3-small
# MATCH_THRESHOLD=0.05
# MATCH_COUNT=8
