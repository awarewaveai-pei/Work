{
  "mcpServers": {
    "wordpress": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@automattic/mcp-wordpress-remote@latest"
      ],
      "env": {
        "WP_API_URL": "https://YOUR_WORDPRESS_SITE/",
        "JWT_TOKEN": "${WP_APPLICATION_PASSWORD}"
      }
    },
    "replicate": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "replicate-mcp"
      ],
      "env": {
        "REPLICATE_API_TOKEN": "${REPLICATE_API_TOKEN}",
        "REPLICATE_WEBHOOK_SIGNING_KEY": "${REPLICATE_WEBHOOK_SIGNING_KEY}"
      }
    },
    "n8n": {
      "type": "http",
      "url": "https://YOUR_INSTANCE.app.n8n.cloud/mcp-server/http",
      "headers": {
        "Authorization": "Bearer ${N8N_MCP_BEARER_TOKEN}"
      }
    },
    "github": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "work-global": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "${userHome}",
        "${workspaceFolder}"
      ]
    },
    "chatgpt-fast": {
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/run-llm-mcp.ps1",
        "-Provider",
        "openai"
      ],
      "env": {
        "OPENAI_API_KEY": "${OPENAI_API_KEY}",
        "OPENAI_MODEL": "gpt-5.3-chat-latest"
      }
    },
    "chatgpt-latest": {
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/run-llm-mcp.ps1",
        "-Provider",
        "openai"
      ],
      "env": {
        "OPENAI_API_KEY": "${OPENAI_API_KEY}",
        "OPENAI_MODEL": "gpt-5.4"
      }
    },
    "claude-fast": {
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/run-llm-mcp.ps1",
        "-Provider",
        "anthropic"
      ],
      "env": {
        "ANTHROPIC_API_KEY": "${ANTHROPIC_API_KEY}",
        "ANTHROPIC_MODEL": "claude-haiku-4-5-20251001"
      }
    },
    "claude-latest": {
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/run-llm-mcp.ps1",
        "-Provider",
        "anthropic"
      ],
      "env": {
        "ANTHROPIC_API_KEY": "${ANTHROPIC_API_KEY}",
        "ANTHROPIC_MODEL": "claude-sonnet-4-6"
      }
    },
    "perplexity": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@perplexity-ai/mcp-server"
      ],
      "env": {
        "PERPLEXITY_API_KEY": "${PERPLEXITY_API_KEY}"
      }
    },
    "gemini-fast": {
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/run-llm-mcp.ps1",
        "-Provider",
        "gemini"
      ],
      "env": {
        "GEMINI_API_KEY": "${GEMINI_API_KEY}",
        "GEMINI_MODEL": "gemini-2.5-flash"
      }
    },
    "gemini-latest": {
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/run-llm-mcp.ps1",
        "-Provider",
        "gemini"
      ],
      "env": {
        "GEMINI_API_KEY": "${GEMINI_API_KEY}",
        "GEMINI_MODEL": "gemini-3.1-pro-preview"
      }
    },
    "copilot": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp",
      "headers": {
        "Authorization": "Bearer ${env:COPILOT_MCP_BEARER_TOKEN}"
      }
    },
    "trigger": {
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/start-trigger-mcp.ps1"
      ],
      "env": {
        "TRIGGER_PROJECT_REF": "${TRIGGER_PROJECT_REF}"
      }
    }
  }
}
